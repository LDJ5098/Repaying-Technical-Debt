#프로젝트 부가요소
부가 요소/*

# 인증서 파일 (보안상 Git에 올리면 안됨)
server/mosquitto/certs/*
c-client-device/certs/*

# generate-certs.sh 는 제외 (스크립트)
!server/mosquitto/certs/generate-certs.sh

# Node.js & TypeScript (기술 스택 관련)
node_modules/*
dist/
*.tsbuildinfo

# MariaDB & Docker (인프라 관련)
server-docker-compose/mariadb/*
!server-docker-compose/mariadb/.gitkeep
.env

#작업도구
.vs/
.vscode/

#기타 임시 파일
*.log
.DS_Store
Thumbs.db
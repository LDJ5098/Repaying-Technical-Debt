# =========================================================
# 1. 보안 핵심 자산 (Zero Trust)
# =========================================================
# SSH 접속 키
**/ssh-key/**

# 어떤 폴더 아래에 있든 인증서 관련 파일은 절대 금지
**/certs/**

# 환경 변수 및 비밀번호 (실전용 데이터 보호)
.env
*.env
**/.env.*
!**/*.env.example

# =========================================================
# 2. 인프라 런타임 데이터 (Persistence Separation)
# =========================================================
# MariaDB 데이터 실체 (이미 추적 중이라면 캐시 삭제 필요)
**/mariadb/**

# Mosquitto 로그 및 런타임 설정 찌꺼기
**/mosquitto/log/*.log
**/mosquitto/runtime/*

# =========================================================
# 3. 개발 및 빌드 결과물 (Artifacts)
# =========================================================
node_modules/
**/dist/
**/build/
**/out/
*.o
*.out
*.exe
.DS_Store
Thumbs.db
내용 정리